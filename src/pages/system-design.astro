---
import Page from '../layouts/Page.astro';
---

<Page title="USS Suite | Tactical Estimator 2.0" description="Ultimate Security Suite - Professional-grade system design, cable estimation, and labor calculation for commercial security integrators.">
    <div class="container" style="text-align:center; padding:8rem 2rem 4rem;">
        <img src="/assets/images/uss-suite-icon.png" alt="USS Suite" style="width:140px; height:140px; border-radius:28px; box-shadow:0 0 60px rgba(255,215,0,0.15); border:2px solid rgba(255,215,0,0.3); margin-bottom:2rem;" />
        <div style="display:inline-block; background:var(--accent); color:var(--primary); padding:0.4rem 1.2rem; font-size:0.7rem; font-weight:800; letter-spacing:2px; border-radius:100px; margin-bottom:1.5rem;">TACTICAL ESTIMATOR 2.0</div>
        <h1 style="color:var(--accent);">ULTIMATE SECURITY <br><span class="text-accent">SUITE</span></h1>
        <p style="font-size:1.1rem; color:var(--muted); max-width:650px; margin:0 auto 2.5rem; line-height:1.7;">
            Professional-grade system design, cable estimation, and labor calculation built for commercial security integrators. Tablet-first. Mission-ready.
        </p>
        <div style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;">
            <a href="#" class="btn btn-primary" onclick="alert('Play Store link coming soon after approval.'); return false;">
                <i class="fab fa-google-play"></i>
                <div><div style="font-size:0.6rem; font-weight:600; opacity:0.7; text-transform:uppercase; letter-spacing:1px;">Get It On</div><div>Google Play</div></div>
            </a>
            <a href="https://xr3keedn.insforge.site" target="_blank" class="btn btn-secondary">
                <i class="fas fa-globe"></i>
                <div><div style="font-size:0.6rem; font-weight:600; opacity:0.7; text-transform:uppercase; letter-spacing:1px;">Launch</div><div>Web App</div></div>
            </a>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-block"><div class="stat-num">500+</div><div class="stat-label">Devices</div></div>
        <div class="stat-block"><div class="stat-num">3D</div><div class="stat-label">Visualization</div></div>
        <div class="stat-block"><div class="stat-num">AI</div><div class="stat-label">Powered</div></div>
        <div class="stat-block"><div class="stat-num">$0</div><div class="stat-label">Subscription</div></div>
    </div>

    <section class="section section-dark">
        <div class="container" style="text-align:center;">
            <h2 class="section-title anim">SEE IT IN ACTION</h2>
            <p class="anim" style="color:var(--muted); max-width:500px; margin:0 auto;">Real tools, real results. Built from the field up.</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; max-width:1100px; margin:3rem auto 0; padding:0 2rem;">
            <div class="anim" style="background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; transition:var(--ease);">
                <img src="/assets/images/uss-screen-3.png" alt="Floorplan Designer" style="width:100%; height:320px; object-fit:cover; display:block;" />
                <div style="padding:1rem; text-align:center; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:1px; color:var(--muted);"><span style="color:var(--accent);">Floorplan Designer</span> &mdash; Interactive site layout</div>
            </div>
            <div class="anim" style="background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; transition:var(--ease);">
                <img src="/assets/images/uss-screen-2.png" alt="Device Placement" style="width:100%; height:320px; object-fit:cover; display:block;" />
                <div style="padding:1rem; text-align:center; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:1px; color:var(--muted);"><span style="color:var(--accent);">Device Placement</span> &mdash; Camera & sensor layout</div>
            </div>
            <div class="anim" style="background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; transition:var(--ease);">
                <img src="/assets/images/uss-screen-4.png" alt="Cable Estimation" style="width:100%; height:320px; object-fit:cover; display:block;" />
                <div style="padding:1rem; text-align:center; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:1px; color:var(--muted);"><span style="color:var(--accent);">Cable Estimation</span> &mdash; Auto-run calculations</div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container" style="text-align:center;"><h2 class="section-title anim">BUILT FOR THE FIELD</h2></div>
        <div class="grid-auto">
            <div class="card anim"><i class="fas fa-drafting-compass"></i><h3>System Designer</h3><p>Interactive canvas with drag-and-drop camera placement, FOV visualization, and real-time coverage mapping.</p></div>
            <div class="card anim"><i class="fas fa-network-wired"></i><h3>Cable Estimator</h3><p>Auto-calculate cable runs with accurate distance mapping. Cat6, fiber, coax, and conduit.</p></div>
            <div class="card anim"><i class="fas fa-calculator"></i><h3>Labor Calculator</h3><p>Realistic labor estimates based on device count, cable runs, and complexity factors.</p></div>
            <div class="card anim"><i class="fas fa-file-invoice-dollar"></i><h3>Bid Generator</h3><p>Professional proposals and BOMs exported to PDF. Send to clients on the spot.</p></div>
            <div class="card anim"><i class="fas fa-map-marked-alt"></i><h3>Satellite Imagery</h3><p>Import satellite imagery and floorplans directly into the designer.</p></div>
            <div class="card anim"><i class="fas fa-cloud-upload-alt"></i><h3>Cloud Sync</h3><p>Projects saved and synced across devices. Your data, anywhere.</p></div>
        </div>
    </section>

    <section class="section" style="text-align:center;">
        <h2 class="anim" style="color:var(--accent);">DEPLOY WITH CONFIDENCE</h2>
        <p class="anim" style="color:var(--muted); max-width:500px; margin:0 auto 2rem;">Stop guessing on bids. Start winning more jobs.</p>
        <div class="anim" style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;">
            <a href="#" class="btn btn-primary" onclick="alert('Play Store link coming soon.'); return false;">
                <i class="fab fa-google-play"></i>
                <div><div style="font-size:0.6rem; font-weight:600; opacity:0.7; text-transform:uppercase; letter-spacing:1px;">Get It On</div><div>Google Play</div></div>
            </a>
            <a href="https://xr3keedn.insforge.site" target="_blank" class="btn btn-secondary">
                <i class="fas fa-globe"></i>
                <div><div style="font-size:0.6rem; font-weight:600; opacity:0.7; text-transform:uppercase; letter-spacing:1px;">Launch</div><div>Web App</div></div>
            </a>
        </div>
    </section>
</Page>

<style>
    @media (max-width:768px) {
        section.section-dark > div > div:last-child { grid-template-columns:1fr!important; max-width:400px; margin-left:auto; margin-right:auto; }
    }
</style>

---
import Page from '../layouts/Page.astro';
---

<Page title="Contact Us" description="Contact Ultimate Security Solutions for a consultation or rapid response dispatch.">
    <div class="container" style="text-align:center; padding:8rem 2rem 3rem;">
        <h1>SECURE YOUR <span class="text-accent">ASSETS</span></h1>
        <p style="color:var(--muted);">Ready to upgrade your infrastructure? Reach out for a consultation or rapid response dispatch.</p>
    </div>

    <section class="section" style="padding-top:0;">
        <div class="anim" style="max-width:1000px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:3rem; background:var(--surface); border:1px solid var(--border); padding:3rem; border-radius:var(--radius);">
            <div>
                <h2 style="color:var(--accent); font-size:1.8rem; margin-bottom:0.5rem;">GET IN TOUCH</h2>
                <p style="color:var(--muted); margin-bottom:2.5rem; font-size:0.95rem;">We respond to all inquiries within 24 hours. For urgent dispatch, call directly.</p>
                <div style="display:flex; align-items:flex-start; gap:1rem; margin-bottom:2rem;">
                    <i class="fas fa-phone-alt" style="font-size:1.2rem; color:var(--accent); margin-top:3px;"></i>
                    <div><h3 style="font-size:0.95rem;">24/7 Operations</h3><p style="color:var(--muted); font-size:0.9rem;">816-814-2007</p></div>
                </div>
                <div style="display:flex; align-items:flex-start; gap:1rem; margin-bottom:2rem;">
                    <i class="fas fa-envelope" style="font-size:1.2rem; color:var(--accent); margin-top:3px;"></i>
                    <div><h3 style="font-size:0.95rem;">General Inquiries</h3><p style="color:var(--muted); font-size:0.9rem;">nate@usstech.net</p></div>
                </div>
                <div style="display:flex; align-items:flex-start; gap:1rem; margin-bottom:2rem;">
                    <i class="fas fa-map-marker-alt" style="font-size:1.2rem; color:var(--accent); margin-top:3px;"></i>
                    <div><h3 style="font-size:0.95rem;">Service Area</h3><p style="color:var(--muted); font-size:0.9rem;">Kansas City Metro &bull; 100-mile Radius</p></div>
                </div>
                <div style="display:flex; gap:1rem; margin-top:2rem;">
                    <a href="https://www.linkedin.com/company/ultimate-security-solutions-llc" target="_blank" rel="noopener" style="width:44px; height:44px; border-radius:50%; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--muted); text-decoration:none; transition:var(--ease);"><i class="fab fa-linkedin-in"></i></a>
                    <a href="https://fieldnation.com/provider/nate-follis" target="_blank" rel="noopener" style="width:44px; height:44px; border-radius:50%; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--muted); text-decoration:none; transition:var(--ease);"><i class="fas fa-globe"></i></a>
                </div>
            </div>
            <div>
                <h3 style="color:var(--text); margin-bottom:1.5rem; font-size:1.25rem;">Request a Quote</h3>
                <form id="contact-form">
                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:0.5rem; font-weight:600;">Full Name</label>
                        <input type="text" id="c-name" class="form-ctrl" placeholder="John Smith" required />
                    </div>
                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:0.5rem; font-weight:600;">Email Address</label>
                        <input type="email" id="c-email" class="form-ctrl" placeholder="john@company.com" required />
                    </div>
                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:0.5rem; font-weight:600;">Phone Number</label>
                        <input type="tel" id="c-phone" class="form-ctrl" placeholder="(816) 555-0000" />
                    </div>
                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:0.5rem; font-weight:600;">Service Needed</label>
                        <select id="c-service" class="form-ctrl">
                            <option value="" disabled selected>Select a service</option>
                            <option value="Cabling">Structured Cabling</option>
                            <option value="CCTV">CCTV Surveillance</option>
                            <option value="Access">Access Control</option>
                            <option value="Network">Network Engineering</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div style="margin-bottom:1.25rem;">
                        <label style="display:block; font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:0.5rem; font-weight:600;">Project Details</label>
                        <textarea id="c-message" class="form-ctrl" rows="4" placeholder="Tell us about your project..." required></textarea>
                    </div>
                    <button type="submit" id="c-btn" class="btn btn-primary" style="width:100%; justify-content:center;"><i class="fas fa-paper-plane"></i> Send Message</button>
                    <div id="c-status" style="margin-top:1rem; text-align:center; display:none;"></div>
                </form>
            </div>
        </div>
    </section>
</Page>

<style>
    .form-ctrl {
        width:100%; padding:0.9rem 1rem; background:rgba(0,0,0,0.3);
        border:1px solid var(--border); color:var(--text); font-family:var(--font);
        border-radius:var(--radius-sm); transition:var(--ease); font-size:0.9rem;
    }
    .form-ctrl:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
    @media (max-width:768px) {
        section .anim > div { grid-template-columns:1fr!important; padding:1.5rem!important; }
    }
</style>

<script>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('c-btn');
        const status = document.getElementById('c-status');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Transmitting...';
        const payload = {
            name: (document.getElementById('c-name')).value,
            email: (document.getElementById('c-email')).value,
            phone: (document.getElementById('c-phone')).value,
            message: `Service: ${(document.getElementById('c-service')).value}\n\n${(document.getElementById('c-message')).value}`
        };
        try {
            const res = await fetch('http://localhost:8000/api/contact/', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
            });
            if (res.ok) {
                status.style.display = 'block'; status.style.color = '#4ade80';
                status.innerHTML = '<i class="fas fa-check-circle"></i> Message received. Dispatch notified.';
                (document.getElementById('contact-form')).reset();
            } else throw new Error();
        } catch {
            window.location.href = `mailto:admin@usstech.net?subject=Contact: ${payload.name}&body=${encodeURIComponent(payload.message)}`;
            status.style.display = 'block'; status.style.color = 'var(--accent)';
            status.innerText = 'Opening email client...';
        } finally { btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Message'; }
    });
</script>
